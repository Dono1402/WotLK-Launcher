<Window x:Class="WotLK.Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="WotLK Launcher"
        Icon="Assets/AppIcon.ico"
        Width="1000"
        Height="563"
        MinWidth="900"
        MinHeight="507"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#020710"
        FontFamily="Georgia"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        SnapsToDevicePixels="True">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="SkinTextBrush" Color="#F2F8FF"/>
        <SolidColorBrush x:Key="SkinMutedBrush" Color="#C3D4E4"/>
        <SolidColorBrush x:Key="SkinGoldBrush" Color="#F2D18D"/>

        <Style x:Key="HiddenChromeButton" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="#01000000"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome" Background="{TemplateBinding Background}"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#203C5E80"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#304B7290"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InvisibleClickButton" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="#01000000"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SkinPathTextBox" TargetType="{x:Type TextBox}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource SkinTextBrush}"/>
            <Setter Property="CaretBrush" Value="#F2F8FF"/>
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="25"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Hidden"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style x:Key="SkinLogTextBox" TargetType="{x:Type TextBox}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#DDEAF6"/>
            <Setter Property="CaretBrush" Value="#DDEAF6"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style x:Key="SkinComboBoxItem" TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Foreground" Value="#F2F8FF"/>
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border x:Name="ItemChrome"
                                Background="#06121E"
                                BorderBrush="#1E4864"
                                BorderThickness="0">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="#12304A"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="#0E263C"/>
                                <Setter Property="Foreground" Value="#F2D18D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SkinComboBox" TargetType="{x:Type ComboBox}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource SkinTextBrush}"/>
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="MaxDropDownHeight" Value="170"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource SkinComboBoxItem}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="#01000000"
                                          BorderThickness="0"
                                          ClickMode="Press"
                                          Focusable="False">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border Background="{TemplateBinding Background}"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              Margin="23,0,58,0"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              IsHitTestVisible="False"/>

                            <Popup x:Name="PART_Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Grid MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                      Margin="0,7,0,0">
                                    <Border Background="#06111D"
                                            BorderBrush="#426783"
                                            BorderThickness="1"
                                            CornerRadius="3">
                                        <ScrollViewer Margin="1"
                                                      CanContentScroll="True"
                                                      SnapsToDevicePixels="True">
                                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SkinProgressBar" TargetType="{x:Type ProgressBar}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#62DFFF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ProgressBar}">
                        <Grid ClipToBounds="True">
                            <Border x:Name="PART_Track" Background="Transparent"/>
                            <Grid x:Name="PART_Indicator"
                                  HorizontalAlignment="Left"
                                  ClipToBounds="True">
                                <Image Source="Assets/Launcher/ExactSkin/progress_fill_icy_blue.png"
                                       Width="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                       Height="{Binding ActualHeight, RelativeSource={RelativeSource TemplatedParent}}"
                                       HorizontalAlignment="Left"
                                       Stretch="Fill"/>
                            </Grid>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryActionClickButton" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="518"/>
            <Setter Property="Height" Value="140"/>
            <Setter Property="Background" Value="#01000000"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}">
                            <Border x:Name="HoverGlow"
                                    CornerRadius="8"
                                    Background="#334BD8FF"
                                    Opacity="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HoverGlow" Property="Opacity" Value="0.22"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="HoverGlow" Property="Opacity" Value="0.1"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SelfUpdateButton" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="#0B1A27"/>
            <Setter Property="BorderBrush" Value="#426783"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <Path Width="18"
                                  Height="18"
                                  Stretch="Uniform"
                                  Stroke="#83E9FF"
                                  StrokeThickness="1.8"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Data="M3,10 A7,7 0 0 1 14.5,4.6 M14.5,4.6 L14.5,1 M14.5,4.6 L18,4.6 M17,10 A7,7 0 0 1 5.5,15.4 M5.5,15.4 L5.5,19 M5.5,15.4 L2,15.4"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#22435F"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#B99955"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#020710">
        <Viewbox Stretch="Uniform">
            <Grid Width="1672" Height="941" ClipToBounds="True">
                <Image Source="Assets/Launcher/ExactSkin/launcher_skin_static_labels_no_play_button.png"
                       Stretch="Fill"
                       IsHitTestVisible="False"/>

                <Canvas Width="1672" Height="941">
                    <Grid Visibility="Collapsed">
                        <TextBlock x:Name="TitleText"/>
                        <TextBlock x:Name="VersionText"/>
                        <TextBlock x:Name="TitleBarText"/>
                    </Grid>

                    <Border Canvas.Left="0"
                            Canvas.Top="0"
                            Width="1438"
                            Height="64"
                            Background="#01000000"
                            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button Canvas.Left="1438"
                            Canvas.Top="0"
                            Width="80"
                            Height="64"
                            Style="{StaticResource HiddenChromeButton}"
                            Click="Minimize_Click"/>
                    <Button Canvas.Left="1518"
                            Canvas.Top="0"
                            Width="72"
                            Height="64"
                            Style="{StaticResource HiddenChromeButton}"
                            Click="MaximizeRestore_Click"/>
                    <Button Canvas.Left="1590"
                            Canvas.Top="0"
                            Width="82"
                            Height="64"
                            Style="{StaticResource HiddenChromeButton}"
                            Click="Close_Click"/>

                    <TextBox x:Name="InstallPathBox"
                             Canvas.Left="330"
                             Canvas.Top="278"
                             Width="620"
                             Height="42"
                             Style="{StaticResource SkinPathTextBox}"
                             IsReadOnly="True"
                             IsTabStop="False"
                             Focusable="False"/>
                    <Button x:Name="BrowseInstallPathButton"
                            Canvas.Left="988"
                            Canvas.Top="258"
                            Width="204"
                            Height="68"
                            Style="{StaticResource InvisibleClickButton}"
                            Click="BrowseInstallPathButton_Click"/>

                    <ComboBox x:Name="GameLanguageComboBox"
                              Canvas.Left="1256"
                              Canvas.Top="261"
                              Width="330"
                              Height="68"
                              Style="{StaticResource SkinComboBox}"
                              SelectionChanged="GameLanguageComboBox_SelectionChanged">
                        <ComboBoxItem Content="Fran&#x00E7;ais" Tag="frFR"/>
                        <ComboBoxItem Content="English" Tag="enUS"/>
                    </ComboBox>

                    <TextBlock x:Name="StatusText"
                               Canvas.Left="142"
                               Canvas.Top="372"
                               Width="285"
                               Height="38"
                               Text="Client &#x00E0; jour - Pr&#x00EA;t &#x00E0; jouer"
                               Foreground="#E5F9FF"
                               FontFamily="Georgia"
                               FontSize="24"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="ProgressText"
                               Canvas.Left="1458"
                               Canvas.Top="378"
                               Width="125"
                               Height="36"
                               Text="Client &#x00E0; jour"
                               Foreground="{StaticResource SkinMutedBrush}"
                               FontFamily="Georgia"
                               FontSize="22"
                               TextAlignment="Right"
                               VerticalAlignment="Center"/>
                    <ProgressBar x:Name="MainProgress"
                                 Canvas.Left="90"
                                 Canvas.Top="438"
                                 Width="1491"
                                 Height="18"
                                 Minimum="0"
                                 Maximum="100"
                                 Style="{StaticResource SkinProgressBar}"/>

                    <TextBox x:Name="LogBox"
                             Canvas.Left="110"
                             Canvas.Top="555"
                             Width="1390"
                             Height="165"
                             Style="{StaticResource SkinLogTextBox}"
                             IsReadOnly="True"/>

                    <Button x:Name="LauncherSelfUpdateButton"
                            Canvas.Left="1388"
                            Canvas.Top="15"
                            Content=""
                            Style="{StaticResource SelfUpdateButton}"
                            Click="LauncherSelfUpdateButton_Click"
                            Visibility="Collapsed"/>

                    <Image x:Name="PrimaryActionButtonImage"
                           Canvas.Left="1085"
                           Canvas.Top="745"
                           Width="518"
                           Height="140"
                           Source="Assets/Launcher/ExactSkin/button_install.png"
                           Stretch="Fill"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           IsHitTestVisible="False"/>

                    <Button x:Name="UpdateButton"
                            Canvas.Left="1085"
                            Canvas.Top="745"
                            Content="INSTALLER"
                            Style="{StaticResource PrimaryActionClickButton}"
                            Click="UpdateButton_Click"/>
                </Canvas>
            </Grid>
        </Viewbox>
    </Grid>
</Window>
