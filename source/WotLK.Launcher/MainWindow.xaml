<Window x:Class="WotLK.Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="WotLK Launcher"
        Height="520"
        MinHeight="500"
        Width="920"
        MinWidth="860"
        Background="#101418"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EAF0F6"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="#F7FAFC"/>
            <Setter Property="Background" Value="#151B21"/>
            <Setter Property="BorderBrush" Value="#36414D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#F7FAFC"/>
            <Setter Property="Background" Value="#202A33"/>
            <Setter Property="BorderBrush" Value="#4A5866"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#8B1E1E"/>
            <Setter Property="BorderBrush" Value="#D8A434"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="SmallTopButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Background" Value="#18212A"/>
            <Setter Property="BorderBrush" Value="#4C6275"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock x:Name="TitleText"
                           Text="WotLK Launcher"
                           FontSize="30"
                           FontWeight="SemiBold"
                           Foreground="#FFD948"/>
                <TextBlock Text="Installation, mise à jour et lancement du client WotLK"
                           Foreground="#AAB6C2"
                           Margin="1,4,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Top">
                <Button x:Name="LauncherSelfUpdateButton"
                        Content="Mettre à jour le launcher"
                        Style="{StaticResource SmallTopButton}"
                        Click="LauncherSelfUpdateButton_Click"
                        Visibility="Collapsed"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Dossier jeu" VerticalAlignment="Center"/>
            <TextBox x:Name="InstallPathBox"
                     Grid.Row="0"
                     Grid.Column="1"
                     Margin="0,0,0,8"
                     IsReadOnly="True"
                     IsTabStop="False"
                     Focusable="False"/>
        </Grid>

        <Border Grid.Row="2"
                Background="#0B0F13"
                BorderBrush="#26313A"
                BorderThickness="1"
                CornerRadius="4"
                Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock x:Name="StatusText"
                               Text="Prêt."
                               DockPanel.Dock="Left"
                               Foreground="#FFD948"
                               FontWeight="SemiBold"/>
                    <TextBlock x:Name="ProgressText"
                               Text=""
                               DockPanel.Dock="Right"
                               Foreground="#AAB6C2"/>
                </DockPanel>
                <TextBox x:Name="LogBox"
                         Grid.Row="1"
                         FontFamily="Consolas"
                         FontSize="12"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"/>
            </Grid>
        </Border>

        <Grid Grid.Row="3" Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ProgressBar x:Name="MainProgress"
                         Grid.Column="0"
                         Height="14"
                         Minimum="0"
                         Maximum="100"
                         VerticalAlignment="Center"
                         Margin="0,0,16,0"/>
            <Button x:Name="UpdateButton"
                    Grid.Column="1"
                    MinWidth="170"
                    Content="Installer"
                    Style="{StaticResource PrimaryButton}"
                    Click="UpdateButton_Click"/>
        </Grid>
    </Grid>
</Window>
