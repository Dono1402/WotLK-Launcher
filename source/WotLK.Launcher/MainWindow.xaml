<Window x:Class="WotLK.Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="WotLK Launcher"
        Icon="Assets/AppIcon.ico"
        Height="560"
        MinHeight="520"
        Width="980"
        MinWidth="900"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#06101A"
        FontFamily="Segoe UI"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        SnapsToDevicePixels="True">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="42"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Color x:Key="InkColor">#07111C</Color>
        <Color x:Key="InkDeepColor">#02060C</Color>
        <Color x:Key="PanelColor">#081522</Color>
        <Color x:Key="PanelTopColor">#102235</Color>
        <Color x:Key="SteelBorderColor">#47708F</Color>
        <Color x:Key="SteelSoftColor">#1D3A52</Color>
        <Color x:Key="IceColor">#73E8FF</Color>
        <Color x:Key="IceDeepColor">#1E8FCE</Color>
        <Color x:Key="GoldColor">#D9B86E</Color>
        <Color x:Key="GoldDeepColor">#84672F</Color>

        <SolidColorBrush x:Key="TextMainBrush" Color="#F2F7FF"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#9DB0C5"/>
        <SolidColorBrush x:Key="IceBrush" Color="{StaticResource IceColor}"/>
        <SolidColorBrush x:Key="GoldBrush" Color="{StaticResource GoldColor}"/>
        <SolidColorBrush x:Key="SteelBorderBrush" Color="{StaticResource SteelBorderColor}"/>

        <LinearGradientBrush x:Key="WindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#081421" Offset="0"/>
            <GradientStop Color="#0A1D2D" Offset="0.45"/>
            <GradientStop Color="#02060C" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="PanelBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="{StaticResource PanelTopColor}" Offset="0"/>
            <GradientStop Color="{StaticResource PanelColor}" Offset="0.46"/>
            <GradientStop Color="#050B13" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="InputBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#0C1723" Offset="0"/>
            <GradientStop Color="#060C13" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ButtonSteelBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#17314A" Offset="0"/>
            <GradientStop Color="#08131F" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ButtonSteelHoverBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#1F4967" Offset="0"/>
            <GradientStop Color="#0D2234" Offset="1"/>
        </LinearGradientBrush>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
        </Style>

        <Style x:Key="FormLabel" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Foreground" Value="#B9C9DA"/>
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Margin" Value="2,0,0,8"/>
        </Style>

        <Style x:Key="IconPath" TargetType="Path">
            <Setter Property="Stroke" Value="#D9E8F6"/>
            <Setter Property="StrokeThickness" Value="1.5"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <Style x:Key="WindowTitleButton" TargetType="Button">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Foreground" Value="#B7C8D8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#17324A"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#0C2237"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Foreground" Value="#F3F8FF"/>
            <Setter Property="Background" Value="{StaticResource ButtonSteelBrush}"/>
            <Setter Property="BorderBrush" Value="#A98B4C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <Grid>
                                <Border Margin="1"
                                        BorderBrush="#274D67"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Opacity="0.65"/>
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"
                                                  RecognizesAccessKey="True"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource ButtonSteelHoverBrush}"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#D6B56D"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#092033"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Foreground" Value="#FBE8B8"/>
            <Setter Property="Background" Value="#12334F"/>
            <Setter Property="BorderBrush" Value="#D4B16A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinHeight" Value="62"/>
            <Setter Property="MinWidth" Value="260"/>
            <Setter Property="Padding" Value="34,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="23"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid>
                            <Path Data="M17,0 L245,0 L264,17 L264,45 L245,62 L17,62 L0,45 L0,17 Z"
                                  Fill="#06111C"
                                  Stroke="#6F5529"
                                  StrokeThickness="1"
                                  Stretch="Fill"/>
                            <Path x:Name="ButtonFill"
                                  Data="M22,7 L240,7 L256,22 L256,40 L240,55 L22,55 L8,40 L8,22 Z"
                                  Stroke="#D9B86E"
                                  StrokeThickness="1.2"
                                  Stretch="Fill">
                                <Path.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#1A5B86" Offset="0"/>
                                        <GradientStop Color="#0B2034" Offset="0.58"/>
                                        <GradientStop Color="#07101B" Offset="1"/>
                                    </LinearGradientBrush>
                                </Path.Fill>
                                <Path.Effect>
                                    <DropShadowEffect Color="#2CCFFF"
                                                      BlurRadius="10"
                                                      ShadowDepth="0"
                                                      Opacity="0.22"/>
                                </Path.Effect>
                            </Path>
                            <Path Data="M0,31 L20,24 L31,31 L20,38 Z"
                                  Fill="#D6B76F"
                                  Stroke="#573E1E"
                                  StrokeThickness="1"
                                  HorizontalAlignment="Left"
                                  Width="34"
                                  Height="18"
                                  Stretch="Fill"/>
                            <Path Data="M0,31 L20,24 L31,31 L20,38 Z"
                                  Fill="#D6B76F"
                                  Stroke="#573E1E"
                                  StrokeThickness="1"
                                  HorizontalAlignment="Right"
                                  Width="34"
                                  Height="18"
                                  Stretch="Fill">
                                <Path.RenderTransform>
                                    <ScaleTransform ScaleX="-1" CenterX="17"/>
                                </Path.RenderTransform>
                            </Path>
                            <ContentPresenter x:Name="ButtonContent"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True">
                                <ContentPresenter.Effect>
                                    <DropShadowEffect Color="#000000"
                                                      BlurRadius="3"
                                                      ShadowDepth="1"
                                                      Opacity="0.9"/>
                                </ContentPresenter.Effect>
                            </ContentPresenter>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonFill" Property="Stroke" Value="#F0D48B"/>
                                <Setter TargetName="ButtonFill" Property="Opacity" Value="1"/>
                                <Setter Property="Foreground" Value="#FFF3CE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonFill" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.46"/>
                                <Setter Property="Foreground" Value="#89939F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PathTextBox" TargetType="TextBox">
            <Setter Property="Foreground" Value="#F4F8FC"/>
            <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="#3E5B72"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <Grid>
                                <Path Data="M2,6 L7,6 L9,8 L18,8 L18,17 L2,17 Z M2,9 L18,9"
                                      Style="{StaticResource IconPath}"
                                      Width="18"
                                      Height="15"
                                      Margin="14,0,0,0"
                                      HorizontalAlignment="Left"
                                      VerticalAlignment="Center"/>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="44,0,12,0"
                                              VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#668BA6"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource IceBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LogTextBox" TargetType="TextBox">
            <Setter Property="Foreground" Value="#D8E7F8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Foreground" Value="#F3F8FF"/>
            <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="#3E5B72"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,0,36,0"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          Focusable="False"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border x:Name="Chrome"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                CornerRadius="4">
                                            <Grid>
                                                <ContentPresenter Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentStringFormat="{Binding SelectionBoxItemStringFormat, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  Margin="{Binding Padding, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Left"/>
                                                <Path Data="M0,0 L5,5 L10,0"
                                                      Stroke="#D9B86E"
                                                      StrokeThickness="2"
                                                      Width="12"
                                                      Height="7"
                                                      Stretch="Fill"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,14,0"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#668BA6"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#D9B86E"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Grid MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border Background="#07111B"
                                            BorderBrush="#3E5B72"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Margin="0,4,0,0">
                                        <ScrollViewer Margin="2"
                                                      CanContentScroll="True">
                                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#F3F8FF"/>
            <Setter Property="Background" Value="#07111B"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border x:Name="ItemChrome"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="#173957"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="#1B4569"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatusBadge" TargetType="Border">
            <Setter Property="Background" Value="#102436"/>
            <Setter Property="BorderBrush" Value="#4087A7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Foreground" Value="{StaticResource IceBrush}"/>
            <Setter Property="Background" Value="#07111A"/>
            <Setter Property="BorderBrush" Value="#24455D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ProgressBar}">
                        <Grid ClipToBounds="True">
                            <Border x:Name="PART_Track"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="5"/>
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    Margin="2"
                                    CornerRadius="4">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#B8FBFF" Offset="0"/>
                                        <GradientStop Color="{StaticResource IceColor}" Offset="0.42"/>
                                        <GradientStop Color="{StaticResource IceDeepColor}" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect Color="#55E9FF"
                                                      BlurRadius="9"
                                                      ShadowDepth="0"
                                                      Opacity="0.62"/>
                                </Border.Effect>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LogExpander" TargetType="Expander">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Expander}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <ToggleButton x:Name="HeaderSite"
                                          Grid.Row="0"
                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Foreground="{TemplateBinding Foreground}"
                                          Cursor="Hand">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Grid>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="24"
                                                        Height="24"
                                                        CornerRadius="12"
                                                        BorderBrush="#6D91AB"
                                                        BorderThickness="1"
                                                        Background="#0D1B29">
                                                    <Path x:Name="Chevron"
                                                          Data="M0,6 L6,0 L12,6"
                                                          Stroke="#D9E8F6"
                                                          StrokeThickness="1.7"
                                                          Width="12"
                                                          Height="7"
                                                          Stretch="Fill"
                                                          RenderTransformOrigin="0.5,0.5"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center">
                                                        <Path.RenderTransform>
                                                            <RotateTransform Angle="180"/>
                                                        </Path.RenderTransform>
                                                    </Path>
                                                </Border>
                                                <ContentPresenter Margin="10,0,0,0"
                                                                  VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Chevron" Property="RenderTransform">
                                                    <Setter.Value>
                                                        <RotateTransform Angle="0"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <ContentPresenter ContentSource="Header"/>
                            </ToggleButton>
                            <ContentPresenter x:Name="ExpandSite"
                                              Grid.Row="1"
                                              Visibility="Collapsed"
                                              ContentSource="Content"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="42"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#06101A" Offset="0"/>
                    <GradientStop Color="#081827" Offset="0.5"/>
                    <GradientStop Color="#03070D" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Width="22"
                    Height="22"
                    Margin="12,0,10,0"
                    CornerRadius="4"
                    BorderBrush="#3F8CB8"
                    BorderThickness="1"
                    VerticalAlignment="Center"
                    Background="#0D2740">
                <Path Data="M11,2 L15,9 L21,11 L15,13 L11,20 L7,13 L1,11 L7,9 Z M11,7 L13,11 L11,15 L9,11 Z"
                      Fill="#78E8FF"
                      Stroke="#BDF8FF"
                      StrokeThickness="0.6"
                      Margin="3"
                      Stretch="Uniform"/>
            </Border>
            <TextBlock x:Name="TitleBarText"
                       Grid.Column="1"
                       Text="WotLK Launcher - v1.0.23"
                       Foreground="#B6C6D7"
                       FontFamily="Georgia"
                       FontSize="13"
                       VerticalAlignment="Center"/>
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <Button Content="−"
                        Style="{StaticResource WindowTitleButton}"
                        Click="Minimize_Click"/>
                <Button Content="□"
                        Style="{StaticResource WindowTitleButton}"
                        Click="MaximizeRestore_Click"/>
                <Button Content="×"
                        Style="{StaticResource WindowTitleButton}"
                        Click="Close_Click"
                        FontSize="22"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1"
              Margin="18">
            <Border CornerRadius="18"
                    BorderBrush="#6D91AB"
                    BorderThickness="1"
                    ClipToBounds="True">
                <Border.Effect>
                    <DropShadowEffect Color="#000000"
                                      Direction="270"
                                      ShadowDepth="9"
                                      BlurRadius="22"
                                      Opacity="0.44"/>
                </Border.Effect>
                <Grid Background="{StaticResource PanelBackgroundBrush}">
                    <Rectangle Opacity="0.08">
                        <Rectangle.Fill>
                            <DrawingBrush TileMode="Tile"
                                          Viewport="0,0,180,120"
                                          ViewportUnits="Absolute"
                                          Stretch="None">
                                <DrawingBrush.Drawing>
                                    <DrawingGroup>
                                        <GeometryDrawing Brush="Transparent">
                                            <GeometryDrawing.Geometry>
                                                <RectangleGeometry Rect="0,0,180,120"/>
                                            </GeometryDrawing.Geometry>
                                        </GeometryDrawing>
                                        <GeometryDrawing>
                                            <GeometryDrawing.Pen>
                                                <Pen Brush="#7ADFFF" Thickness="0.35"/>
                                            </GeometryDrawing.Pen>
                                            <GeometryDrawing.Geometry>
                                                <GeometryGroup>
                                                    <LineGeometry StartPoint="12,16" EndPoint="76,10"/>
                                                    <LineGeometry StartPoint="96,42" EndPoint="166,34"/>
                                                    <LineGeometry StartPoint="32,93" EndPoint="142,105"/>
                                                </GeometryGroup>
                                            </GeometryDrawing.Geometry>
                                        </GeometryDrawing>
                                    </DrawingGroup>
                                </DrawingBrush.Drawing>
                            </DrawingBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <Canvas HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Width="230"
                            Height="190"
                            Opacity="0.12"
                            Margin="0,6,20,0"
                            IsHitTestVisible="False">
                        <Path Stroke="#65C6F3"
                              StrokeThickness="2"
                              Data="M140,6 L166,54 L214,80 L166,106 L140,154 L114,106 L66,80 L114,54 Z"/>
                        <Path Stroke="#65C6F3"
                              StrokeThickness="1.4"
                              Data="M140,42 L154,68 L180,80 L154,92 L140,118 L126,92 L100,80 L126,68 Z"/>
                        <Path Stroke="#65C6F3"
                              StrokeThickness="1"
                              Data="M44,126 L86,92 L116,130 L92,162 Z"/>
                    </Canvas>

                    <Border BorderBrush="#1E8FCE"
                            BorderThickness="1"
                            CornerRadius="17"
                            Opacity="0.55"
                            Margin="2"/>

                    <Grid Margin="32,26,32,24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Bottom">
                                <TextBlock x:Name="TitleText"
                                           Text="WotLK Launcher"
                                           FontFamily="Georgia"
                                           FontSize="36"
                                           FontWeight="Bold"
                                           VerticalAlignment="Bottom">
                                    <TextBlock.Foreground>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#FFF5C9" Offset="0"/>
                                            <GradientStop Color="#D7B86B" Offset="0.52"/>
                                            <GradientStop Color="#8E6B31" Offset="1"/>
                                        </LinearGradientBrush>
                                    </TextBlock.Foreground>
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#000000"
                                                          BlurRadius="4"
                                                          ShadowDepth="2"
                                                          Opacity="0.95"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                                <TextBlock x:Name="VersionText"
                                           Text="v1.0.23"
                                           Foreground="#C1D7EB"
                                           FontFamily="Georgia"
                                           FontSize="18"
                                           Margin="18,0,0,8"
                                           VerticalAlignment="Bottom"/>
                            </StackPanel>

                            <Button x:Name="LauncherSelfUpdateButton"
                                    Grid.Column="1"
                                    Content="Mise à jour launcher"
                                    Style="{StaticResource SecondaryButton}"
                                    MinWidth="166"
                                    Click="LauncherSelfUpdateButton_Click"
                                    Visibility="Collapsed"/>
                        </Grid>

                        <TextBlock Grid.Row="1"
                                   Text="Installation, mise à jour et lancement du client WotLK"
                                   Foreground="#B7C8D8"
                                   FontFamily="Georgia"
                                   FontSize="15"
                                   Margin="2,6,0,16"/>

                        <Grid Grid.Row="2"
                              Margin="0,0,0,22">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="132"/>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="190"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Text="Dossier jeu"
                                       Style="{StaticResource FormLabel}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,14,0"/>
                            <TextBox x:Name="InstallPathBox"
                                     Grid.Row="1"
                                     Grid.Column="1"
                                     Style="{StaticResource PathTextBox}"
                                     MinWidth="0"
                                     IsReadOnly="True"
                                     IsTabStop="False"
                                     Focusable="False"/>
                            <Button x:Name="BrowseInstallPathButton"
                                    Grid.Row="1"
                                    Grid.Column="2"
                                    Style="{StaticResource SecondaryButton}"
                                    MinHeight="40"
                                    Margin="8,0,0,0"
                                    Click="BrowseInstallPathButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M2,6 L7,6 L9,8 L18,8 L18,17 L2,17 Z M2,9 L18,9"
                                          Style="{StaticResource IconPath}"
                                          Width="18"
                                          Height="15"
                                          Margin="0,0,9,0"/>
                                    <TextBlock Text="Parcourir"
                                               Foreground="#F3F8FF"
                                               FontFamily="Georgia"
                                               FontSize="15"/>
                                </StackPanel>
                            </Button>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="4"
                                       Text="Langue jeu"
                                       Style="{StaticResource FormLabel}"/>
                            <ComboBox x:Name="GameLanguageComboBox"
                                      Grid.Row="1"
                                      Grid.Column="4"
                                      Style="{StaticResource DarkComboBox}"
                                      MinWidth="0"
                                      HorizontalAlignment="Stretch"
                                      SelectionChanged="GameLanguageComboBox_SelectionChanged">
                                <ComboBoxItem Content="Français" Tag="frFR"/>
                                <ComboBoxItem Content="English" Tag="enUS"/>
                            </ComboBox>
                        </Grid>

                        <Grid Grid.Row="3"
                              Margin="0,0,0,20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Row="0"
                                    Grid.Column="0"
                                    Style="{StaticResource StatusBadge}"
                                    HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="10"
                                            Height="10"
                                            CornerRadius="5"
                                            Background="#6FFFF0"
                                            Margin="0,0,10,0"
                                            VerticalAlignment="Center">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#6FFFF0"
                                                              BlurRadius="8"
                                                              ShadowDepth="0"
                                                              Opacity="0.9"/>
                                        </Border.Effect>
                                    </Border>
                                    <TextBlock x:Name="StatusText"
                                               Text="Client à jour - Prêt à jouer"
                                               Foreground="#DDF9FF"
                                               FontFamily="Georgia"
                                               FontSize="15"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <TextBlock x:Name="ProgressText"
                                       Grid.Row="0"
                                       Grid.Column="1"
                                       Text="Client à jour"
                                       Foreground="#B8D4EC"
                                       FontFamily="Georgia"
                                       FontSize="14"
                                       VerticalAlignment="Center"/>
                            <ProgressBar x:Name="MainProgress"
                                         Grid.Row="1"
                                         Grid.ColumnSpan="2"
                                         Minimum="0"
                                         Maximum="100"
                                         Margin="0,12,0,0"/>
                        </Grid>

                        <Expander Grid.Row="4"
                                  Style="{StaticResource LogExpander}"
                                  IsExpanded="True">
                            <Expander.Header>
                                <TextBlock Text="Logs techniques"
                                           Foreground="#B7C8D8"
                                           FontFamily="Georgia"
                                           FontSize="15"/>
                            </Expander.Header>
                            <Border Background="#07101A"
                                    BorderBrush="#45647C"
                                    BorderThickness="1"
                                    CornerRadius="5"
                                    Height="124"
                                    Margin="0,10,0,0">
                                <Grid>
                                    <Border BorderBrush="#0F2B42"
                                            BorderThickness="1"
                                            Margin="1"
                                            CornerRadius="4"
                                            Opacity="0.7"/>
                                    <TextBox x:Name="LogBox"
                                             Style="{StaticResource LogTextBox}"
                                             IsReadOnly="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Disabled"/>
                                </Grid>
                            </Border>
                        </Expander>

                        <Grid Grid.Row="5"
                              Margin="0,18,0,0">
                            <Button x:Name="UpdateButton"
                                    HorizontalAlignment="Right"
                                    Content="INSTALLER"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="UpdateButton_Click"/>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
